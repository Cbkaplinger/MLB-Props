# Copy these values into your shell profile or local environment.
# Do not commit machine-specific paths.

# Directory containing raw/ and processed/ subdirectories.
MLB_PROPS_DATA_DIR=/path/to/mlb-props-data

# Optional: override the exact pitcher-start training file.
# MLB_PROPS_PITCHER_STARTS=/path/to/Pitcher2023-2025.parquet

# Optional: write models, predictions, and SHAP tables elsewhere.
# MLB_PROPS_OUTPUT_DIR=/path/to/mlb-props-artifacts

# Optional: override raw Statcast season directories.
# MLB_PROPS_SAVANT_DATA_DIR=/path/to/savant/regular
